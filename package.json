{
  "name": "mcp-refactor-typescript",
  "version": "2.1.0",
  "description": "MCP server for TypeScript/JavaScript code refactoring using TypeScript Language Server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-refactor-typescript": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Stefan-Nitu/mcp-refactor-typescript.git"
  },
  "author": "Stefan Nitu",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "javascript",
    "refactoring",
    "lsp",
    "language-server"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "bun test --timeout 30000 src/",
    "test:unit": "bun test src/**/*.unit.test.ts src/**/*.contract.test.ts",
    "test:integration": "bun test --timeout 30000 src/**/*.integration.test.ts src/**/*.e2e.test.ts",
    "test:watch": "bun test --watch --concurrency 1 src/",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "pino": "^10.0.0",
    "tsr": "^1.3.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.10.6",
    "husky": "^9.1.7",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.8"
  }
}
